{
    "version": 8,
    "name": "name",
    "glyphs": "{fontstack}{range}",
	"sprite": "http://localhost:8000/sprites/krøyer",
    "sources": {
        "vector-source": {
            "type": "vector",
            "tiles": ["https://api.dataforsyningen.dk/wmts/skaermkort_vector_tiles_labs/v1?REQUEST=GetTile&SERVICE=WMTS&VERSION=1.0.0&LAYER=skaermkort_vector_tiles&STYLE=&TILEMATRIX=EPSG:25832:{z}&TILEMATRIXSET=EPSG:25832&FORMAT=application/vnd.mapbox-vector-tile&TILECOL={x}&TILEROW={y}"],
            "maxZoom": 16,
            "minZoom": 0
        }, 
		"skib": {
			"type": "geojson", 
			"data": "http://localhost:8000/sprites/skib.geojson"
        }
    },
    "layers": [
        {
            "id": "skib",
            "source": "skib",
			"type": "circle",
			"paint": {
				"circle-color": "#FF0000",
				"circle-radius": 100
			}
		},
		{
            "id": "vand_hav",
            "source-layer": "vand",
            "type": "fill",
            "filter": ["all", ["==", "type", "hav"]],
            "paint": {
                "fill-pattern": "hav"
            },
            "source": "vector-source"
        }
    ],
    "metadata": {
        "maputnik:renderer": "ol"
    }
}